---
// La raíz redirige al locale por defecto (o al preferido del navegador).
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0; url=/es/" />
    <link rel="canonical" href="/es/" />
    <title>Maximiliano Stranich</title>
  </head>
  <body>
    <script>
      const stored = localStorage.getItem('locale');
      const preferred =
        stored ?? (navigator.language.toLowerCase().startsWith('en') ? 'en' : 'es');
      location.replace(`/${preferred === 'en' ? 'en' : 'es'}/`);
    </script>
    <a href="/es/">Español</a> · <a href="/en/">English</a>
  </body>
</html>
